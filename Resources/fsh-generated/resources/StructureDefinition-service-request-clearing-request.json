  "name": "ServiceRequestClearingRequest",
  "title": "Anfrage zum Ausstellen einer Verordnung",
  "status": "draft",
  "experimental": false,
  "publisher": "gematik GmbH",
  "description": "ServiceRequest, der genutzt wird um ein Rezept anzufragen",
